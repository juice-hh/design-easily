# Copy this file to .env and fill in your API key

# Port for the local server (default: 3771)
PORT=3771

# Anthropic API key (for Claude models)
ANTHROPIC_API_KEY=sk-ant-...

# Default AI model
DEFAULT_MODEL=claude-sonnet-4-6

# Target project root — used when the browser element has no source file info
# (happens with SWC compiler / Next.js production builds)
# WORKSPACE_PATH=/Users/yourname/projects/my-nextjs-app

# Claude model used for code edits (default: haiku for speed, change to sonnet for complex edits)
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# CLAUDE_MODEL=claude-sonnet-4-6
