{
  "name": "design-easily",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "extension",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ext\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:ext": "npm run dev --workspace=extension",
    "build": "npm run build --workspace=extension && npm run build --workspace=server",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.3",
    "concurrently": "^8.2.2",
    "jsdom": "^29.0.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.3"
  }
}
